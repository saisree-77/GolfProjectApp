<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         version="3.1">

    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.app.servlet.RegisterServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/RegisterServlet</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.app.servlet.LoginServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/LoginServlet</url-pattern>
    </servlet-mapping>
    <servlet>
    <servlet-name>SubscriptionServlet</servlet-name>
    <servlet-class>com.app.servlet.SubscriptionServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>SubscriptionServlet</servlet-name>
    <url-pattern>/SubscriptionServlet</url-pattern>
</servlet-mapping>
<servlet>
    <servlet-name>ScoreServlet</servlet-name>
    <servlet-class>com.app.servlet.ScoreServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>ScoreServlet</servlet-name>
    <url-pattern>/ScoreServlet</url-pattern>
</servlet-mapping>
<servlet>
    <servlet-name>LuckyDrawServlet</servlet-name>
    <servlet-class>com.app.servlet.LuckyDrawServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>LuckyDrawServlet</servlet-name>
    <url-pattern>/LuckyDrawServlet</url-pattern>
</servlet-mapping>

</web-app>